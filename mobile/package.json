{
  "name": "daily-log-mobile",
  "version": "1.2.0",
  "private": true,
  "description": "Capacitor wrapper that bundles daily-log.html into a self-contained Android app.",
  "scripts": {
    "sync-web": "node sync-web.js",
    "add:android": "cap add android",
    "sync": "cap sync android",
    "assets": "capacitor-assets generate --android --iconBackgroundColor #0E1512 --iconBackgroundColorDark #0E1512 --splashBackgroundColor #0E1512 --splashBackgroundColorDark #0E1512",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/share": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.0"
  }
}
